# Mapbox public token (pk.*) for the Map of the Body of Christ.
# Sign up at https://account.mapbox.com/ — free tier is generous.
VITE_MAPBOX_TOKEN=

# Mapbox style URL. Default is mapbox/light-v11; replace with your custom
# style URL (mapbox://styles/<owner>/<style-id>) for the bespoke look.
VITE_MAPBOX_STYLE=mapbox://styles/mapbox/light-v11

# ── Supabase ─────────────────────────────────────────────────────
# Required once the localStorage prototype is migrated to Supabase.
# Find both in your Supabase project's API settings.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Service-role secrets (server-only — never expose to the client) ──
# Used by the edge functions in supabase/functions/. Set via
# `supabase secrets set --env-file ./supabase/.env.production`.
# Do NOT add VITE_ prefix — these must NOT be bundled.
# RESEND_API_KEY=re_...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

